# Last-Minute Life Saver Backend Config
PORT=8000
HOST=0.0.0.0

# Gemini API Key (Generate at https://aistudio.google.com/)
GEMINI_API_KEY=your_gemini_api_key_here 

# Firestore DB Configuration
# To use Firestore, download a firebase service account credential JSON and link it here
# FIREBASE_CREDENTIALS_PATH=./firebase-credentials.json
# Or specify your Google Cloud Project ID
# FIRESTORE_PROJECT_ID=your-gcp-project-id

# Set to True to skip Firestore connection check and use memory fallback DB
USE_MOCK_DB=True
